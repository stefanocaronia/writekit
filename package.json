{
  "name": "writekit",
  "version": "0.2.0",
  "description": "CLI framework for creating books — generates PDF, ePub, HTML, and DOCX",
  "type": "module",
  "bin": {
    "wk": "./dist/cli.js",
    "writekit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const{cpSync}=require('fs');cpSync('src/themes','dist/themes',{recursive:true});cpSync('src/types','dist/types',{recursive:true});cpSync('src/agents','dist/agents',{recursive:true})\"",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "keywords": [
    "novel",
    "book",
    "writing",
    "cli",
    "pdf",
    "epub",
    "docx"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/yazl": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^13.0.0",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "marked": "^17.0.4",
    "marked-footnote": "^1.4.0",
    "puppeteer-core": "^24.39.1",
    "yaml": "^2.8.2",
    "yazl": "^3.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
